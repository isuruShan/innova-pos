NODE_ENV=development
PORT=5000
SERVICE_NAME=pos-server

# Database — paste full connection string (local or MongoDB Atlas). Atlas strings ARE URIs, e.g.
# mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/innovapos?retryWrites=true&w=majority
# URL-encode special characters in the password. You can use any one of:
# MONGO_URI | MONGODB_URI | MONGODB_ATLAS_URI (same value; first set wins)
MONGO_URI=mongodb://127.0.0.1:27017/innovapos

# JWT (MUST match all other services)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_CRYPTO_RANDOMBYTES_64
JWT_EXPIRES_IN=12h

# Upload service URL
UPLOAD_SERVICE_URL=http://localhost:3002

# Audit service URL
AUDIT_SERVICE_URL=http://localhost:3004

# Optional: Redis for POS notification SSE pub/sub across PM2 workers (not used for HTTP rate limiting).
# If Redis requires a password, include it in the URL:
# REDIS_URL=redis://:YOUR_PASSWORD@127.0.0.1:6379
# REDIS_URL=redis://127.0.0.1:6379

# CORS (leave empty in dev to allow all)
# CORS_ORIGIN=http://localhost:5173
