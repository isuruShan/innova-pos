NODE_ENV=development
PORT=5000
SERVICE_NAME=pos-server

# Database (shared across all services)
MONGO_URI=mongodb://127.0.0.1:27017/innovapos

# JWT (MUST match all other services)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_CRYPTO_RANDOMBYTES_64
JWT_EXPIRES_IN=12h

# Upload service URL
UPLOAD_SERVICE_URL=http://localhost:3002

# Audit service URL
AUDIT_SERVICE_URL=http://localhost:3004

# Optional: Redis for global rate limits across multiple Node processes (RATE_LIMIT_REDIS_URL overrides REDIS_URL)
# REDIS_URL=redis://127.0.0.1:6379

# CORS (leave empty in dev to allow all)
# CORS_ORIGIN=http://localhost:5173
