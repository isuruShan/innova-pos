# Vite env vars must be prefixed with VITE_
# These are baked into the bundle at build time.
# On EC2, set these before building:
#   VITE_ADMIN_URL=https://admin.yourdomain.com
#   VITE_QR_ORDER_WEB_ORIGIN=https://order.yourdomain.com
#   (legacy) VITE_PUBLIC_ORDER_PAGE_ORIGIN=https://yourdomain.com

# POS API base URL (leave blank to use Vite proxy in dev)
# VITE_API_URL=http://localhost:5000/api

# URL of the Admin Portal (used in the avatar dropdown for merchant_admin users)
VITE_ADMIN_URL=http://localhost:5174

# Base URL of the standalone guest table-order app (Café tables QR links)
# VITE_QR_ORDER_WEB_ORIGIN=http://localhost:5180
# Legacy fallback if VITE_QR_ORDER_WEB_ORIGIN is unset:
# VITE_PUBLIC_ORDER_PAGE_ORIGIN=http://localhost:5180
