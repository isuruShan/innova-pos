# Vite env vars must be prefixed with VITE_
# These are baked into the bundle at build time.
# On EC2, set these before building:
#   VITE_POS_URL=https://pos.yourdomain.com

# Admin Portal API base URL (leave blank to use Vite proxy in dev)
# VITE_API_URL=http://localhost:5001/api

# URL of the POS app (used in the sidebar "Open POS App" link for merchant_admin users)
VITE_POS_URL=http://localhost:5173
