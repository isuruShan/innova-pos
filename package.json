{
  "name": "innovasolutions-pos-platform",
  "version": "1.0.0",
  "private": true,
  "description": "InnovaSolutions multi-tenant POS platform monorepo",
  "scripts": {
    "pos:server": "pnpm --filter @pos/server dev",
    "pos:client": "pnpm --filter @pos/client dev",
    "auth": "pnpm --filter @services/auth-service dev",
    "upload": "pnpm --filter @services/upload-service dev",
    "public-web": "pnpm --filter @public-web/server --filter @public-web/client --parallel dev",
    "qr-order": "pnpm --filter @qr-order/server --filter @qr-order/client --parallel dev",
    "build:qr-order-client": "pnpm --filter @qr-order/client run build",
    "admin": "pnpm --filter @admin-portal/server --filter @admin-portal/client --parallel dev",
    "dev": "pnpm --parallel --filter './apps/**' --filter './services/**' dev",
    "migrate:tenant": "node ./scripts/migrate-add-tenantid.js"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "mongoose": "^9.6.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}

