NODE_ENV=development
PORT=3002
SERVICE_NAME=upload-service

# AWS Configuration
AWS_REGION=us-east-1
AWS_S3_BUCKET=innovapos-uploads-dev

# For local dev: use a named AWS profile (no hardcoded keys)
# Set up with: aws configure --profile innovapos-dev
# AWS_PROFILE=innovapos-dev

# For production on EC2: leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY unset.
# The SDK will automatically use the EC2 instance role via IMDS.

# Upload limits
MAX_IMAGE_SIZE_MB=5
MAX_DOC_SIZE_MB=10

# Image optimization (all raster uploads → WebP before S3)
UPLOAD_MAX_IMAGE_DIMENSION=2048
WEBP_QUALITY=82

# Auth (must match JWT_SECRET used by auth-service)
JWT_SECRET=CHANGE_ME_SAME_AS_AUTH_SERVICE

# Same random secret as public-web server — required for BR uploads from public-web (header x-service-key).
# If empty here, the service also reads repo-root .env when present.
INTERNAL_SERVICE_KEY=

# CORS (comma-separated, leave empty in dev to allow all)
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Audit service URL
AUDIT_SERVICE_URL=http://localhost:3004
