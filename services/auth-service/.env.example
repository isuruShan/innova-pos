NODE_ENV=development
PORT=3001
SERVICE_NAME=auth-service

# Database (shared with POS). Atlas: use full mongodb+srv string as MONGO_URI (or MONGODB_ATLAS_URI).
MONGO_URI=mongodb://127.0.0.1:27017/innovapos

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_WITH_CRYPTO_RANDOMBYTES_64
JWT_EXPIRES_IN=12h

# CORS (comma-separated, leave empty in dev to allow all)
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Email — Nodemailer only (Gmail or any SMTP)
EMAIL_FROM=innovasolutionslk@gmail.com
EMAIL_APP_PASSWORD=fqcxzwjhjklsboeb

# Optional: use a transactional SMTP provider instead of Gmail
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# URLs for emails
POS_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
FRONTEND_URL=http://localhost:5173

# Audit service
AUDIT_SERVICE_URL=http://localhost:3004
